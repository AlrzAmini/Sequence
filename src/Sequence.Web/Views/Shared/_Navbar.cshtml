<!-- Views/Shared/_Navbar.cshtml -->
@using Microsoft.AspNetCore.Identity
@using Sequence.Web.Domain.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
}

<nav class="navbar">
    <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">

        <!-- Logo -->
        <a href="@Url.Action("Index", "Home")"
           class="flex items-center gap-2 text-cinema-accent font-bold text-xl hover:text-yellow-400 transition-colors">
            🎬 <span>سکانس</span>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden md:flex items-center gap-1">
            <a asp-controller="Movies" asp-action="Index"
               class="btn-ghost text-sm">فیلم‌ها</a>

            @if (SignInManager.IsSignedIn(User))
            {
                <a asp-controller="Watchlist" asp-action="Index"
                   class="btn-ghost text-sm">لیست تماشا</a>
                <a asp-controller="Dashboard" asp-action="Index"
                   class="btn-ghost text-sm">داشبورد</a>
            }
        </div>

        <!-- Right Side: Auth -->
        <div class="flex items-center gap-3">
            @if (SignInManager.IsSignedIn(User))
            {
                <!-- User Menu -->
                <div class="relative" id="userMenu">
                    <button onclick="toggleUserMenu()"
                            class="flex items-center gap-2 hover:text-white transition-colors group">
                        @if (!string.IsNullOrEmpty(user?.AvatarUrl))
                        {
                            <img src="@user.AvatarUrl" alt="آواتار"
                                 class="w-8 h-8 rounded-full object-cover border border-cinema-border group-hover:border-cinema-accent" />
                        }
                        else
                        {
                            <div class="w-8 h-8 rounded-full bg-cinema-accent/20 border border-cinema-accent/50 flex items-center justify-center text-cinema-accent text-sm font-bold">
                                @(user?.DisplayName?.FirstOrDefault())
                            </div>
                        }
                        <span class="text-sm text-cinema-muted group-hover:text-white">@user?.DisplayName</span>
                        <svg class="w-4 h-4 text-cinema-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <!-- Dropdown -->
                    <div id="userDropdown"
                         class="hidden absolute left-0 top-12 w-48 bg-cinema-card border border-cinema-border rounded-xl shadow-2xl py-1 z-50 animate-fade-in">
                        <a asp-controller="Account" asp-action="Profile"
                           class="flex items-center gap-2 px-4 py-2.5 text-sm hover:bg-cinema-surface transition-colors">
                            👤 پروفایل
                        </a>
                        <a asp-controller="Movies" asp-action="Create"
                           class="flex items-center gap-2 px-4 py-2.5 text-sm hover:bg-cinema-surface transition-colors">
                            ➕ افزودن فیلم
                        </a>
                        <hr class="border-cinema-border my-1">
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit"
                                    class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-cinema-red hover:bg-red-950/30 transition-colors text-right">
                                🚪 خروج
                            </button>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"
                   class="btn-ghost text-sm">ورود</a>
                <a asp-controller="Account" asp-action="Register"
                   class="btn-primary text-sm">ثبت‌نام</a>
            }
        </div>
    </div>
</nav>

<script>
    function toggleUserMenu() {
        const dropdown = document.getElementById('userDropdown');
        dropdown.classList.toggle('hidden');
    }

    // Close on outside click
    document.addEventListener('click', function (e) {
        const menu = document.getElementById('userMenu');
        if (menu && !menu.contains(e.target)) {
            document.getElementById('userDropdown')?.classList.add('hidden');
        }
    });
</script>