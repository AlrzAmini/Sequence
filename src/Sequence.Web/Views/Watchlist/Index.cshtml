<!-- Views/Watchlist/Index.cshtml -->
@model List<Sequence.Web.ViewModels.Watchlist.WatchlistItemViewModel>
@{
    ViewData["Title"] = "لیست تماشا";
    Layout = "_Layout";
}

<div class="max-w-5xl mx-auto px-4 py-10">

    <div class="flex items-center justify-between mb-8">
        <div>
            <h1 class="text-3xl font-black text-white">📋 لیست تماشا</h1>
            <p class="text-cinema-muted mt-1">@Model.Count فیلم در انتظار تماشا</p>
        </div>
        <a asp-action="Add" class="btn-primary flex items-center gap-2">
            ➕ افزودن فیلم
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-24 bg-cinema-card border border-cinema-border rounded-2xl">
            <div class="text-7xl mb-6">📺</div>
            <h2 class="text-2xl font-bold text-white mb-3">لیست تماشا خالی است</h2>
            <p class="text-cinema-muted mb-8">فیلم‌هایی که می‌خواهید ببینید را اینجا اضافه کنید</p>
            <a asp-action="Add" class="btn-primary">افزودن اولین فیلم</a>
        </div>
    }
    else
    {
        <div class="grid gap-4">
            @foreach (var item in Model)
            {
                <div class="bg-cinema-card border border-cinema-border rounded-xl p-5
                            hover:border-cinema-border/80 transition-colors flex gap-4 items-center">

                    <!-- Poster -->
                    <div class="w-16 h-24 flex-shrink-0 rounded-lg overflow-hidden bg-cinema-surface
                                flex items-center justify-center">
                        @if (!string.IsNullOrEmpty(item.PosterUrl))
                        {
                            <img src="@item.PosterUrl" alt="@item.MovieTitle"
                                 class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <span class="text-2xl">🎬</span>
                        }
                    </div>

                    <!-- Info -->
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start justify-between gap-3">
                            <div>
                                <h3 class="text-white font-semibold truncate">@item.MovieTitle</h3>
                                @if (!string.IsNullOrEmpty(item.OriginalTitle))
                                {
                                    <p class="text-cinema-muted text-xs" dir="ltr">@item.OriginalTitle</p>
                                }
                            </div>
                            <span class="genre-badge flex-shrink-0">@item.GenreDisplay</span>
                        </div>

                        <div class="flex items-center gap-3 mt-2 text-xs text-cinema-muted">
                            @if (item.ReleaseYear.HasValue)
                            {
                                <span>📅 @item.ReleaseYear</span>
                            }
                            <span>اضافه شده: @item.AddedAt.ToString("dd/MM/yyyy")</span>
                        </div>

                        @if (!string.IsNullOrEmpty(item.Notes))
                        {
                            <p class="text-cinema-muted text-xs mt-2 italic">💭 @item.Notes</p>
                        }
                    </div>

                    <!-- Actions -->
                    <div class="flex flex-col gap-2 flex-shrink-0">
                        <a asp-action="MarkWatched" asp-route-id="@item.Id"
                           class="btn-primary text-xs px-4 py-2 text-center whitespace-nowrap">
                            ✅ تماشا کردم
                        </a>
                        <form asp-action="Remove" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit"
                                    class="btn-ghost text-xs w-full text-cinema-red hover:text-red-400"
                                    onclick="return confirm('از لیست حذف شود؟')">
                                🗑️ حذف
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>