<!-- Views/Dashboard/Index.cshtml -->
@model Sequence.Web.ViewModels.Dashboard.DashboardViewModel
@using Microsoft.AspNetCore.Identity
@using Sequence.Web.Domain.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "داشبورد";
    var user = await UserManager.GetUserAsync(User);
}

<div class="max-w-7xl mx-auto px-4 py-10">

    <!-- Welcome -->
    <div class="mb-10">
        <h1 class="text-3xl font-black text-white">
            سلام، @user?.DisplayName 👋
        </h1>
        <p class="text-cinema-muted mt-1">اینجا خلاصه‌ای از فعالیت‌های سینمایی شما است</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
        @{
            var stats = new[]
            {
                ("🎬", Model.TotalMoviesWatched.ToString(), "فیلم تماشا شده", "border-cinema-accent"),
                ("📋", Model.MoviesInWatchlist.ToString(), "در لیست تماشا", "border-blue-700"),
                ("⭐", Model.AveragePersonalRating.ToString("F1"), "میانگین امتیاز", "border-cinema-gold"),
                ("✍️", Model.TotalReviews.ToString(), "نقد نوشته شده", "border-green-700"),
            };
        }

        @foreach (var (icon, value, label, borderColor) in stats)
        {
            <div class="bg-cinema-card border @borderColor border-opacity-50 rounded-2xl p-6 text-center
                hover:border-opacity-100 transition-all duration-300">
                <div class="text-4xl mb-3">@icon</div>
                <div class="text-3xl font-black text-white mb-1">@value</div>
                <div class="text-cinema-muted text-sm">@label</div>
            </div>
        }
    </div>

    <!-- Recently Watched -->
    @if (Model.RecentlyWatched.Any())
    {
        <section class="mb-12">
            <div class="flex items-center justify-between mb-6">
                <h2 class="section-title mb-0">🕐 اخیراً تماشا شده</h2>
                <a asp-controller="Movies" asp-action="Index"
                   class="text-cinema-accent hover:text-yellow-400 text-sm transition-colors">
                    همه فیلم‌ها ←
                </a>
            </div>
            <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-3">
                @foreach (var movie in Model.RecentlyWatched)
                {
                    @await Html.PartialAsync("_MovieMiniCard", movie)
                }
            </div>
        </section>
    }

    <!-- Top Row: Highest Rated + Most Discussed -->
    <div class="grid md:grid-cols-2 gap-8 mb-12">

        <!-- Highest Rated -->
        @if (Model.HighestRated.Any())
        {
            <section>
                <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
                    🏆 بالاترین امتیاز
                </h2>
                <div class="space-y-3">
                    @foreach (var (movie, index) in Model.HighestRated.Take(5).Select((m, i) => (m, i)))
                    {
                        <a asp-controller="Movies" asp-action="Detail" asp-route-id="@movie.Id"
                           class="flex items-center gap-3 p-3 bg-cinema-card border border-cinema-border
                            rounded-xl hover:border-cinema-accent/50 transition-all group">
                            <span class="text-cinema-muted font-bold text-sm w-6 text-center">
                                @(index + 1)
                            </span>
                            @if (!string.IsNullOrEmpty(movie.PosterUrl))
                            {
                                <img src="@movie.PosterUrl" alt="@movie.Title"
                                     class="w-8 h-12 object-cover rounded" />
                            }
                            else
                            {
                                <div class="w-8 h-12 bg-cinema-surface rounded flex items-center justify-center text-xs">🎬</div>
                            }
                            <div class="flex-1 min-w-0">
                                <p class="text-white text-sm font-medium truncate group-hover:text-cinema-accent transition-colors">
                                    @movie.Title
                                </p>
                                <p class="text-cinema-muted text-xs">@movie.ReleaseYear</p>
                            </div>
                            <div class="@(movie.PersonalRating >= 8 ? "rating-high" : movie.PersonalRating >= 5 ? "rating-mid" : "rating-low") rating-circle w-8 h-8 text-xs">
                                @movie.PersonalRating
                            </div>
                        </a>
                    }
                </div>
            </section>
        }

        <!-- Recent Reviews -->
        @if (Model.RecentReviews.Any())
        {
            <section>
                <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
                    ✍️ نقدهای اخیر
                </h2>
                <div class="space-y-3">
                    @foreach (var review in Model.RecentReviews.Take(5))
                    {
                        <a asp-controller="Reviews" asp-action="Detail" asp-route-id="@review.ReviewId"
                           class="flex items-start gap-3 p-3 bg-cinema-card border border-cinema-border
                            rounded-xl hover:border-cinema-accent/50 transition-all group">
                            @if (!string.IsNullOrEmpty(review.MoviePosterUrl))
                            {
                                <img src="@review.MoviePosterUrl" alt="@review.MovieTitle"
                                     class="w-8 h-12 object-cover rounded flex-shrink-0" />
                            }
                            else
                            {
                                <div class="w-8 h-12 bg-cinema-surface rounded flex items-center justify-center text-xs flex-shrink-0">🎬</div>
                            }
                            <div class="flex-1 min-w-0">
                                <p class="text-cinema-accent text-xs mb-0.5">@review.MovieTitle</p>
                                <p class="text-white text-sm line-clamp-2 group-hover:text-cinema-text transition-colors">
                                    @review.BodyPreview
                                </p>
                                <p class="text-cinema-muted text-xs mt-1">
                                    @review.AuthorDisplayName · @review.CreatedAt.ToString("dd/MM")
                                </p>
                            </div>
                        </a>
                    }
                </div>
            </section>
        }
    </div>

    <!-- Quick Actions -->
    <section class="bg-cinema-card border border-cinema-border rounded-2xl p-8">
        <h2 class="text-xl font-bold text-white mb-6">⚡ دسترسی سریع</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <a asp-controller="Movies" asp-action="Create"
               class="flex flex-col items-center gap-3 p-5 bg-cinema-surface border border-cinema-border
                rounded-xl hover:border-cinema-accent/50 hover:bg-cinema-accent/5 transition-all text-center group">
                <span class="text-3xl group-hover:scale-110 transition-transform">🎬</span>
                <span class="text-sm text-cinema-muted group-hover:text-white transition-colors">افزودن فیلم</span>
            </a>
            <a asp-controller="Watchlist" asp-action="Add"
               class="flex flex-col items-center gap-3 p-5 bg-cinema-surface border border-cinema-border
                rounded-xl hover:border-cinema-accent/50 hover:bg-cinema-accent/5 transition-all text-center group">
                <span class="text-3xl group-hover:scale-110 transition-transform">📋</span>
                <span class="text-sm text-cinema-muted group-hover:text-white transition-colors">لیست تماشا</span>
            </a>
            <a asp-controller="Watchlist" asp-action="Index"
               class="flex flex-col items-center gap-3 p-5 bg-cinema-surface border border-cinema-border
                rounded-xl hover:border-cinema-accent/50 hover:bg-cinema-accent/5 transition-all text-center group">
                <span class="text-3xl group-hover:scale-110 transition-transform">📺</span>
                <span class="text-sm text-cinema-muted group-hover:text-white transition-colors">مشاهده لیست</span>
            </a>
            <a asp-controller="Account" asp-action="Profile"
               class="flex flex-col items-center gap-3 p-5 bg-cinema-surface border border-cinema-border
                rounded-xl hover:border-cinema-accent/50 hover:bg-cinema-accent/5 transition-all text-center group">
                <span class="text-3xl group-hover:scale-110 transition-transform">👤</span>
                <span class="text-sm text-cinema-muted group-hover:text-white transition-colors">پروفایل</span>
            </a>
        </div>
    </section>
</div>