<!-- Views/Shared/_ValidationScripts.cshtml -->
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

<script>
    // Override validation styles to match our dark theme
    $.validator.setDefaults({
    highlight: function(element) {
    $(element).addClass('border-cinema-red focus:border-cinema-red');
    },
    unhighlight: function(element) {
    $(element).removeClass('border-cinema-red focus:border-cinema-red');
    }
    });
</script>