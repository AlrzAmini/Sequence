<!-- Views/Movies/Create.cshtml -->
@model Sequence.Web.ViewModels.Movies.MovieCreateViewModel
@{
    ViewData["Title"] = "افزودن فیلم";
    Layout = "_Layout";
}

<div class="max-w-2xl mx-auto px-4 py-10">
    <div class="mb-8">
        <a asp-action="Index" class="text-cinema-muted hover:text-white text-sm flex items-center gap-2 mb-4">
            ← بازگشت به فیلم‌ها
        </a>
        <h1 class="text-3xl font-black text-white">🎬 افزودن فیلم جدید</h1>
        <p class="text-cinema-muted mt-2">فیلمی که تماشا کرده‌اید را ثبت کنید</p>
    </div>

    <div class="bg-cinema-card border border-cinema-border rounded-2xl p-8">
        <form asp-action="Create" method="post" id="movieForm">
            @Html.AntiForgeryToken()

            <div class="space-y-6">

                <!-- Title -->
                <div>
                    <label asp-for="Title" class="input-label">عنوان فارسی *</label>
                    <input asp-for="Title" class="input-field" placeholder="مثال: شاهکار فیلم‌سازی" />
                    <span asp-validation-for="Title" class="text-cinema-red text-xs mt-1 block"></span>
                </div>

                <!-- Original Title -->
                <div>
                    <label asp-for="OriginalTitle" class="input-label">عنوان اصلی (اختیاری)</label>
                    <input asp-for="OriginalTitle" class="input-field" placeholder="مثال: Masterpiece" dir="ltr" />
                    <span asp-validation-for="OriginalTitle" class="text-cinema-red text-xs mt-1 block"></span>
                </div>

                <!-- Poster URL -->
                <div>
                    <label asp-for="PosterUrl" class="input-label">آدرس پوستر (اختیاری)</label>
                    <input asp-for="PosterUrl" class="input-field" dir="ltr"
                           placeholder="https://example.com/poster.jpg"
                           oninput="previewPoster(this.value)" />
                    <span asp-validation-for="PosterUrl" class="text-cinema-red text-xs mt-1 block"></span>
                    <!-- Poster Preview -->
                    <div id="posterPreview" class="mt-3 hidden">
                        <img id="posterImg" class="w-24 h-36 object-cover rounded-lg border border-cinema-border" />
                    </div>
                </div>

                <!-- Year + Genre row -->
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="ReleaseYear" class="input-label">سال اکران *</label>
                        <input asp-for="ReleaseYear" type="number" class="input-field"
                               min="1888" max="2100" placeholder="1402" />
                        <span asp-validation-for="ReleaseYear" class="text-cinema-red text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Genre" class="input-label">ژانر *</label>
                        <select asp-for="Genre" asp-items="ViewBag.Genres" class="input-field">
                            <option value="">انتخاب ژانر</option>
                        </select>
                        <span asp-validation-for="Genre" class="text-cinema-red text-xs mt-1 block"></span>
                    </div>
                </div>

                <!-- Personal Rating (Star Component) -->
                <div>
                    <label class="input-label">امتیاز شخصی (۱ تا ۱۰) *</label>
                    <div class="star-rating" id="starRating" data-name="PersonalRating">
                        @for (int i = 10; i >= 1; i--)
                        {
                            <span class="star" data-value="@i">★</span>
                        }
                    </div>
                    <input type="hidden" asp-for="PersonalRating" id="PersonalRating" />
                    <span id="ratingDisplay" class="text-cinema-accent text-sm mt-1 block"></span>
                    <span asp-validation-for="PersonalRating" class="text-cinema-red text-xs mt-1 block"></span>
                </div>

                <!-- Watched Date -->
                <div>
                    <label asp-for="WatchedDate" class="input-label">تاریخ تماشا *</label>
                    <input asp-for="WatchedDate" type="date" class="input-field"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="WatchedDate" class="text-cinema-red text-xs mt-1 block"></span>
                </div>

                <!-- Short Review -->
                <div>
                    <label asp-for="ShortReview" class="input-label">
                        خلاصه نظر (اختیاری)
                        <span id="shortReviewCount" class="text-cinema-muted font-normal">۰/۱۰۰۰</span>
                    </label>
                    <textarea asp-for="ShortReview" class="input-field resize-none" rows="4"
                              placeholder="در چند جمله درباره این فیلم بنویسید..."
                              maxlength="1000"
                              oninput="updateCount('ShortReview', 'shortReviewCount', 1000)"></textarea>
                    <span asp-validation-for="ShortReview" class="text-cinema-red text-xs mt-1 block"></span>
                </div>

                <!-- Submit -->
                <div class="flex gap-3 pt-2">
                    <button type="submit" class="btn-primary flex-1 flex items-center justify-center gap-2"
                            id="submitBtn">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        ثبت فیلم
                    </button>
                    <a asp-action="Index" class="btn-secondary">انصراف</a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function previewPoster(url) {
            const preview = document.getElementById('posterPreview');
            const img = document.getElementById('posterImg');
            if (url && url.startsWith('http')) {
                img.src = url;
                img.onload = () => preview.classList.remove('hidden');
                img.onerror = () => preview.classList.add('hidden');
            } else {
                preview.classList.add('hidden');
            }
        }

        function updateCount(fieldId, countId, max) {
            const field = document.getElementById(fieldId);
            const counter = document.getElementById(countId);
            if (field && counter) {
                counter.textContent = `${field.value.length}/${max}`;
            }
        }

        // Form loading state
        document.getElementById('movieForm').addEventListener('submit', function() {
            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> در حال ثبت...';
        });
    </script>
}